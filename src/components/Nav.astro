---
import Wordmark from './Wordmark.astro';
const links = [
  { href: '/#products', label: 'Products' },
  { href: '/#work', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="carpuro.ai home">
      <Wordmark size={22} />
    </a>
    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a href="/contact" class="btn btn-primary nav-cta">Get in touch</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(180%) blur(6px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .brand { display: inline-flex; align-items: center; }
  .nav-links { display: none; gap: var(--s-8); }
  .nav-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color .15s ease;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta { padding: 0.55rem 1.1rem; font-size: 0.9rem; }

  @media (min-width: 880px) {
    .nav-links { display: flex; }
  }
</style>
