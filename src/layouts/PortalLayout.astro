---
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  active?: string;
  admin?: boolean;
}
const {
  title = 'Client portal — carpuro.ai',
  description = 'Your carpuro.ai client portal.',
  active = 'projects',
  admin = false,
} = Astro.props;

const nav = admin
  ? [
      { id: 'leads', label: 'Leads', href: '/admin', icon: 'inbox' },
      { id: 'projects', label: 'Projects', href: '/admin/projects', icon: 'grid' },
      { id: 'clients', label: 'Clients', href: '/admin/clients', icon: 'users' },
    ]
  : [{ id: 'projects', label: 'Projects', href: '/portal', icon: 'grid' }];
const help = admin
  ? []
  : [
      { id: 'book', label: 'Book a call', href: '/contact#book', icon: 'calendar' },
      { id: 'contact', label: 'Contact', href: '/contact', icon: 'mail' },
    ];
const groupLabel = admin ? 'Admin' : 'Workspace';

const ICONS: Record<string, string> = {
  grid: '<svg class="sb-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>',
  inbox: '<svg class="sb-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>',
  users: '<svg class="sb-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  calendar: '<svg class="sb-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>',
  mail: '<svg class="sb-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>',
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#16161a" />
    <link rel="icon" type="image/svg+xml" href="/assets/carpuro-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="portal-body" data-admin={admin ? '1' : '0'}>
    <div class="app-shell">
      <!-- SIDEBAR -->
      <aside class="sidebar" id="sidebar">
        <a href="/" class="sb-brand" aria-label="carpuro.ai home">
          carpuro<span>.ai</span>
        </a>

        <nav class="sb-nav" aria-label="Portal">
          <p class="sb-group">{groupLabel}</p>
          {nav.map((i) => (
            <a href={i.href} class:list={['sb-link', { 'is-active': active === i.id }]}
               aria-current={active === i.id ? 'page' : undefined}>
              <Fragment set:html={ICONS[i.icon]} />
              <span>{i.label}</span>
            </a>
          ))}

          {help.length > 0 && <p class="sb-group">Get help</p>}
          {help.map((i) => (
            <a href={i.href} class="sb-link">
              <Fragment set:html={ICONS[i.icon]} />
              <span>{i.label}</span>
            </a>
          ))}
        </nav>

        <!-- ACCOUNT MENU (bottom) -->
        <div class="sb-account">
          <div class="sb-menu" id="acctMenu" hidden>
            <a href={admin ? '/portal' : '/admin'} class="sb-menu-item" id="acctSwitch" hidden={!admin}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
              {admin ? 'Client portal' : 'Admin dashboard'}
            </a>
            <a href="/" class="sb-menu-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
              Back to carpuro.ai
            </a>
            <button type="button" class="sb-menu-item" id="signOut">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
              Sign out
            </button>
          </div>
          <button type="button" class="sb-acct-btn" id="acctBtn" aria-haspopup="true" aria-expanded="false">
            <span class="sb-avatar" id="acctAvatar">·</span>
            <span class="sb-acct-text">
              <span class="sb-acct-name" id="acctName">Loading…</span>
              <span class="sb-acct-mail" id="acctMail"></span>
            </span>
            <svg class="sb-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 15 6-6 6 6"/></svg>
          </button>
        </div>
      </aside>

      <!-- MAIN -->
      <div class="app-main">
        <header class="app-top">
          <button type="button" class="sb-toggle" id="sbToggle" aria-label="Toggle sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
          </button>
          <slot name="top" />
        </header>
        <div class="app-content">
          <slot />
        </div>
      </div>
    </div>

    {/* Project assistant — project-aware chat for the logged-in client only
        (separate from the marketing lead-gen chat; calls /api/portal-chat). */}
    {!admin && (
    <Fragment>
    <button type="button" class="pa-bubble" id="paBubble" aria-label="Open project assistant">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </button>
    <section class="pa-panel" id="paPanel" hidden aria-label="Project assistant">
      <header class="pa-head">
        <span class="pa-title">Project assistant</span>
        <button type="button" class="pa-close" id="paClose" aria-label="Close assistant">✕</button>
      </header>
      <div class="pa-msgs" id="paMsgs">
        <div class="pa-msg pa-bot">Hi — ask me anything about your projects: status, what’s next, or recent updates.</div>
      </div>
      <form class="pa-form" id="paForm">
        <input type="text" id="paInput" placeholder="Ask about your projects…" autocomplete="off" />
        <button type="submit" aria-label="Send">→</button>
      </form>
    </section>
    </Fragment>
    )}

    <script>
      import { getPortalClient } from '../lib/portalClient';
      const supabase = getPortalClient();

      // Gate every portal page at the shell level.
      const isAdminPage = document.body.dataset.admin === '1';
      (async () => {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) { location.replace('/portal/login'); return; }

        const email = session.user.email ?? '';
        const { data: profile } = await supabase
          .from('profiles').select('full_name, role').eq('id', session.user.id).maybeSingle();

        // Admin-only pages: bounce non-admins back to the client portal.
        if (isAdminPage && profile?.role !== 'admin') { location.replace('/portal'); return; }
        // On client pages, reveal the admin shortcut for admins.
        if (!isAdminPage && profile?.role === 'admin') {
          document.getElementById('acctSwitch')?.removeAttribute('hidden');
        }

        const name = profile?.full_name || email.split('@')[0] || 'Your account';
        const nameEl = document.getElementById('acctName');
        const mailEl = document.getElementById('acctMail');
        const avEl = document.getElementById('acctAvatar');
        if (nameEl) nameEl.textContent = name;
        if (mailEl) mailEl.textContent = email;
        if (avEl) avEl.textContent = (name[0] || '·').toUpperCase();
      })();

      // Account dropdown
      const acctBtn = document.getElementById('acctBtn');
      const acctMenu = document.getElementById('acctMenu');
      acctBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = acctMenu?.hasAttribute('hidden');
        if (open) { acctMenu?.removeAttribute('hidden'); acctBtn.setAttribute('aria-expanded', 'true'); }
        else { acctMenu?.setAttribute('hidden', ''); acctBtn.setAttribute('aria-expanded', 'false'); }
      });
      document.addEventListener('click', () => {
        acctMenu?.setAttribute('hidden', '');
        acctBtn?.setAttribute('aria-expanded', 'false');
      });

      document.getElementById('signOut')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        location.replace('/portal/login');
      });

      // Mobile sidebar toggle
      document.getElementById('sbToggle')?.addEventListener('click', () => {
        document.getElementById('sidebar')?.classList.toggle('is-open');
      });

      // ---- Project assistant chat ----
      const paBubble = document.getElementById('paBubble');
      const paPanel = document.getElementById('paPanel');
      const paMsgs = document.getElementById('paMsgs');
      const paForm = document.getElementById('paForm') as HTMLFormElement | null;
      const paInput = document.getElementById('paInput') as HTMLInputElement | null;
      const paHistory: { role: string; content: string }[] = [];

      const openPa = (open: boolean) => {
        if (!paPanel || !paBubble) return;
        if (open) { paPanel.removeAttribute('hidden'); paBubble.setAttribute('hidden', ''); paInput?.focus(); }
        else { paPanel.setAttribute('hidden', ''); paBubble.removeAttribute('hidden'); }
      };
      paBubble?.addEventListener('click', () => openPa(true));
      document.getElementById('paClose')?.addEventListener('click', () => openPa(false));

      const paAdd = (text: string, who: 'user' | 'bot') => {
        const d = document.createElement('div');
        d.className = `pa-msg pa-${who}`;
        d.textContent = text;
        paMsgs?.appendChild(d);
        if (paMsgs) paMsgs.scrollTop = paMsgs.scrollHeight;
        return d;
      };

      paForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = paInput?.value.trim();
        if (!text) return;
        paAdd(text, 'user');
        paHistory.push({ role: 'user', content: text });
        if (paInput) paInput.value = '';
        const thinking = paAdd('…', 'bot');
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) { thinking.textContent = 'Please sign in again.'; return; }
        try {
          const res = await fetch('/api/portal-chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session.access_token}` },
            body: JSON.stringify({ message: text, history: paHistory }),
          });
          const data = await res.json();
          thinking.textContent = data.reply || '…';
          paHistory.push({ role: 'assistant', content: data.reply || '' });
        } catch {
          thinking.textContent = 'Couldn’t reach the assistant — please try again.';
        }
      });
    </script>

    <style is:global>
      .portal-body { background: var(--bg); }
    </style>

    <style>
      .app-shell { display: flex; min-height: 100vh; }

      /* ---- Sidebar ---- */
      .sidebar {
        width: 248px; flex-shrink: 0; position: sticky; top: 0; height: 100vh;
        background: #15151a; color: rgba(255,255,255,0.72);
        display: flex; flex-direction: column; padding: var(--s-6) var(--s-4);
        border-right: 1px solid rgba(255,255,255,0.08);
      }
      .sb-brand {
        font-family: var(--font-display); font-size: 1.45rem; color: #fff;
        letter-spacing: 0.02em; padding: 0 var(--s-3) var(--s-2); line-height: 1;
      }
      .sb-brand span { color: var(--accent); }

      .sb-nav { margin-top: var(--s-6); flex: 1; display: flex; flex-direction: column; gap: 2px; }
      .sb-group {
        font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.12em;
        text-transform: uppercase; color: rgba(255,255,255,0.38);
        padding: var(--s-4) var(--s-3) var(--s-2);
      }
      .sb-link {
        display: flex; align-items: center; gap: var(--s-3);
        padding: 0.55rem var(--s-3); border-radius: var(--r-sm);
        color: rgba(255,255,255,0.72); font-size: 0.92rem; font-weight: 500;
        transition: background .15s ease, color .15s ease;
      }
      .sb-link:hover { background: rgba(255,255,255,0.06); color: #fff; }
      .sb-link.is-active { background: rgba(255,255,255,0.10); color: #fff; }
      .sb-ico { width: 18px; height: 18px; flex-shrink: 0; }

      /* ---- Account ---- */
      .sb-account { position: relative; border-top: 1px solid rgba(255,255,255,0.08); padding-top: var(--s-3); }
      .sb-acct-btn {
        width: 100%; display: flex; align-items: center; gap: var(--s-3);
        padding: var(--s-2) var(--s-3); border-radius: var(--r-sm);
        background: transparent; color: inherit; text-align: left; cursor: pointer;
        transition: background .15s ease;
      }
      .sb-acct-btn:hover { background: rgba(255,255,255,0.06); }
      .sb-avatar {
        width: 30px; height: 30px; flex-shrink: 0; border-radius: 50%;
        background: var(--accent); color: #fff; font-weight: 700; font-size: 0.85rem;
        display: grid; place-items: center;
      }
      .sb-acct-text { display: grid; min-width: 0; flex: 1; }
      .sb-acct-name { color: #fff; font-size: 0.88rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .sb-acct-mail { font-size: 0.72rem; color: rgba(255,255,255,0.5); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .sb-chev { width: 16px; height: 16px; flex-shrink: 0; color: rgba(255,255,255,0.5); }

      .sb-menu {
        position: absolute; bottom: calc(100% + 6px); left: 0; right: 0;
        background: #1e1e25; border: 1px solid rgba(255,255,255,0.1);
        border-radius: var(--r-md); padding: var(--s-2); box-shadow: var(--shadow-lg);
      }
      .sb-menu-item {
        width: 100%; display: flex; align-items: center; gap: var(--s-3);
        padding: 0.55rem var(--s-3); border-radius: var(--r-sm);
        background: transparent; color: rgba(255,255,255,0.8); font-size: 0.88rem;
        text-align: left; cursor: pointer; transition: background .15s ease, color .15s ease;
      }
      .sb-menu-item:hover { background: rgba(255,255,255,0.07); color: #fff; }
      .sb-menu-item svg { width: 16px; height: 16px; flex-shrink: 0; }

      /* ---- Main ---- */
      .app-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
      .app-top {
        height: 60px; flex-shrink: 0; display: flex; align-items: center; gap: var(--s-4);
        padding: 0 var(--s-8); border-bottom: 1px solid var(--border);
        background: color-mix(in srgb, var(--bg) 90%, transparent); backdrop-filter: blur(6px);
        position: sticky; top: 0; z-index: 20;
      }
      .sb-toggle { display: none; background: transparent; color: var(--text-muted); cursor: pointer; padding: 4px; }
      .sb-toggle svg { width: 20px; height: 20px; }
      .app-content { padding: var(--s-12) var(--s-8); max-width: 1100px; width: 100%; }

      /* ---- Mobile ---- */
      @media (max-width: 860px) {
        .sidebar {
          position: fixed; z-index: 60; left: 0; top: 0;
          transform: translateX(-100%); transition: transform .22s ease;
        }
        .sidebar.is-open { transform: translateX(0); }
        .sb-toggle { display: inline-flex; }
        .app-content { padding: var(--s-8) var(--s-6); }
      }

      /* ---- Project assistant ---- */
      .pa-bubble {
        position: fixed; bottom: 22px; right: 22px; z-index: 80;
        width: 52px; height: 52px; border-radius: 50%; cursor: pointer;
        background: var(--accent); color: #fff; display: grid; place-items: center;
        box-shadow: var(--shadow-lg); transition: transform .15s ease, background .15s ease;
      }
      .pa-bubble:hover { background: var(--accent-hover); transform: translateY(-2px); }
      .pa-bubble svg { width: 22px; height: 22px; }
      .pa-panel {
        position: fixed; bottom: 22px; right: 22px; z-index: 81;
        width: min(380px, calc(100vw - 32px)); height: min(560px, calc(100vh - 44px));
        display: flex; flex-direction: column; overflow: hidden;
        background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--r-lg); box-shadow: var(--shadow-lg);
      }
      .pa-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: var(--s-4) var(--s-5); border-bottom: 1px solid var(--border);
        background: var(--accent-soft);
      }
      .pa-title { font-weight: 600; font-size: 0.95rem; }
      .pa-close { background: transparent; border: 0; color: var(--text-subtle); cursor: pointer; font-size: 0.95rem; }
      .pa-msgs { flex: 1; overflow-y: auto; padding: var(--s-5); display: flex; flex-direction: column; gap: var(--s-3); }
      .pa-msg { max-width: 86%; padding: 0.6rem 0.85rem; border-radius: var(--r-md); font-size: 0.92rem; line-height: 1.45; white-space: pre-wrap; }
      .pa-bot { background: var(--bg-alt); color: var(--text); align-self: flex-start; border-bottom-left-radius: 4px; }
      .pa-user { background: var(--accent); color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
      .pa-form { display: flex; gap: var(--s-2); padding: var(--s-3); border-top: 1px solid var(--border); }
      .pa-form input {
        flex: 1; font-family: var(--font-sans); font-size: 0.92rem; color: var(--text);
        background: var(--bg-alt); border: 1px solid var(--border-strong); border-radius: var(--r-full);
        padding: 0.55rem 0.9rem; outline: none;
      }
      .pa-form input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-ring); }
      .pa-form button {
        flex-shrink: 0; width: 38px; height: 38px; border-radius: 50%; border: 0; cursor: pointer;
        background: var(--accent); color: #fff; font-size: 1.05rem; transition: background .15s ease;
      }
      .pa-form button:hover { background: var(--accent-hover); }
    </style>
  </body>
</html>
