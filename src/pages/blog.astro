---
import Base from '../layouts/Base.astro';
---

<Base title="Writing — Carlos Pulido Rosas" description="Notes on data engineering, pipelines, and applied data science. Coming soon.">
  <section class="section page-hero">
    <div class="container">
      <span class="eyebrow">Writing</span>
      <h1>Notes, soon.</h1>
      <p class="lead">I'm putting together writing on data engineering, pipeline design, and what
        I'm learning building SaaS on top of data infrastructure.</p>

      <div class="soon">
        <p class="soon-label">In the meantime</p>
        <p>Follow along or reach out — happy to talk shop.</p>
        <div class="soon-cta">
          <a href="https://github.com/Carpuro" target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
          <a href="/contact" class="btn btn-primary">Get in touch<span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { padding-top: var(--s-16); }
  .page-hero h1 { margin: var(--s-4) 0 var(--s-6); }
  .soon { margin-top: var(--s-12); padding: var(--s-8); border: 1px solid var(--border); border-left: 4px solid var(--accent); border-radius: var(--r-md); background: var(--surface); max-width: 520px; }
  .soon-label { font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-subtle); margin-bottom: var(--s-2); }
  .soon-cta { display: flex; gap: var(--s-3); margin-top: var(--s-6); flex-wrap: wrap; }
</style>
