---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Your projects — carpuro.ai"
  description="Your carpuro.ai client portal: projects, status, and updates."
>
  <section class="section page-hero portal">
    <div class="container">
      <div class="portal-head">
        <div>
          <span class="eyebrow">Client portal</span>
          <h1 id="greeting">Your projects</h1>
        </div>
        <button type="button" class="btn btn-ghost" id="signOut" hidden>Sign out</button>
      </div>

      <div id="portalState" class="portal-loading">Loading your projects…</div>
      <div id="projectGrid" class="project-grid" hidden></div>
    </div>
  </section>
</Base>

<script>
  import { getPortalClient } from '../../lib/portalClient';
  import { STATUS_META, escapeHtml, fmtDate } from '../../lib/portalUi';

  const supabase = getPortalClient();
  const state = document.getElementById('portalState')!;
  const grid = document.getElementById('projectGrid')!;
  const greeting = document.getElementById('greeting')!;
  const signOutBtn = document.getElementById('signOut') as HTMLButtonElement | null;

  (async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      location.replace('/portal/login');
      return;
    }

    signOutBtn?.removeAttribute('hidden');
    signOutBtn?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      location.replace('/portal/login');
    });

    // Greeting from the profile (RLS: a client only reads their own row).
    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, company, role')
      .eq('id', session.user.id)
      .maybeSingle();
    const firstName = (profile?.full_name || session.user.email || '').split(' ')[0];
    if (firstName) greeting.textContent = `Welcome back, ${firstName}`;

    // Projects (RLS returns only the client's own; admins see all).
    const { data: projects, error } = await supabase
      .from('projects')
      .select('id, name, summary, status, progress, target_date, updated_at')
      .order('updated_at', { ascending: false });

    if (error) {
      state.textContent = 'We couldn’t load your projects right now. Please refresh in a moment.';
      return;
    }

    if (!projects || projects.length === 0) {
      state.innerHTML =
        '<div class="empty card"><h3>No projects yet</h3>' +
        '<p>Once your engagement kicks off, your projects and their status will show up here. ' +
        'Questions in the meantime? <a href="/contact">Reach out</a>.</p></div>';
      return;
    }

    grid.innerHTML = projects
      .map((p) => {
        const meta = STATUS_META[p.status] ?? STATUS_META.discovery;
        const progress = Math.max(0, Math.min(100, p.progress ?? 0));
        return `
        <a class="project-card card" href="/portal/project?id=${encodeURIComponent(p.id)}">
          <div class="pc-top">
            <span class="badge" data-tone="${meta.tone}">${meta.label}</span>
            ${p.target_date ? `<span class="pc-date">Target ${fmtDate(p.target_date)}</span>` : ''}
          </div>
          <h3>${escapeHtml(p.name)}</h3>
          ${p.summary ? `<p class="pc-summary">${escapeHtml(p.summary)}</p>` : ''}
          <div class="pc-progress" aria-label="Progress ${progress}%">
            <div class="pc-bar"><span style="width:${progress}%"></span></div>
            <span class="pc-pct">${progress}%</span>
          </div>
        </a>`;
      })
      .join('');
    state.hidden = true;
    grid.hidden = false;
  })();
</script>

<style>
  .page-hero { padding-top: var(--s-16); }
  .portal-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: var(--s-4); margin-bottom: var(--s-12);
  }
  .portal-head h1 { margin-top: var(--s-4); }
  .portal-loading { color: var(--text-muted); font-family: var(--font-mono); font-size: 0.9rem; }

  .project-grid { display: grid; gap: var(--s-6); }
  @media (min-width: 720px) { .project-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1040px) { .project-grid { grid-template-columns: repeat(3, 1fr); } }

  .project-card { display: block; color: var(--text); }
  .project-card h3 { margin: var(--s-3) 0 var(--s-2); }
  .pc-top { display: flex; align-items: center; justify-content: space-between; gap: var(--s-3); }
  .pc-date { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-subtle); }
  .pc-summary { font-size: 0.92rem; color: var(--text-muted); margin-bottom: var(--s-4); }
  .pc-progress { display: flex; align-items: center; gap: var(--s-3); margin-top: var(--s-4); }
  .pc-bar { flex: 1; height: 6px; border-radius: var(--r-full); background: var(--bg-alt); overflow: hidden; }
  .pc-bar span { display: block; height: 100%; background: var(--accent); border-radius: var(--r-full); }
  .pc-pct { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-subtle); }

  .empty { max-width: 520px; padding: var(--s-8); }
  .empty h3 { margin-bottom: var(--s-3); }
  .empty a { color: var(--accent); }
</style>
