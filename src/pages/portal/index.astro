---
import PortalLayout from '../../layouts/PortalLayout.astro';
---

<PortalLayout title="Your projects — carpuro.ai" active="projects">
  <span slot="top" class="app-title">Projects</span>

  <div class="page-head">
    <h1>Your projects</h1>
    <p class="page-sub">Status, progress, and updates for every engagement.</p>
  </div>

  <div id="portalState" class="portal-loading">Loading your projects…</div>
  <div id="projectGrid" class="project-grid" hidden></div>
</PortalLayout>

<script>
  import { getPortalClient } from '../../lib/portalClient';
  import { STATUS_META, escapeHtml, fmtDate } from '../../lib/portalUi';

  const supabase = getPortalClient();
  const state = document.getElementById('portalState')!;
  const grid = document.getElementById('projectGrid')!;

  (async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return; // the shell handles the redirect

    const { data: projects, error } = await supabase
      .from('projects')
      .select('id, name, summary, status, progress, target_date, updated_at')
      .order('updated_at', { ascending: false });

    if (error) {
      state.textContent = 'We couldn’t load your projects right now. Please refresh in a moment.';
      return;
    }

    if (!projects || projects.length === 0) {
      state.outerHTML = `
        <div class="empty-card">
          <div class="empty-ico" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
          </div>
          <h3>No projects yet</h3>
          <p>Once your engagement kicks off, your projects and their status will show up here.
          Questions in the meantime? <a href="/contact">Reach out</a>.</p>
        </div>`;
      return;
    }

    grid.innerHTML = projects
      .map((p) => {
        const meta = STATUS_META[p.status] ?? STATUS_META.discovery;
        const progress = Math.max(0, Math.min(100, p.progress ?? 0));
        return `
        <a class="project-card" href="/portal/project?id=${encodeURIComponent(p.id)}">
          <div class="pc-top">
            <span class="badge" data-tone="${meta.tone}">${meta.label}</span>
            ${p.target_date ? `<span class="pc-date">Target ${fmtDate(p.target_date)}</span>` : ''}
          </div>
          <h3>${escapeHtml(p.name)}</h3>
          ${p.summary ? `<p class="pc-summary">${escapeHtml(p.summary)}</p>` : ''}
          <div class="pc-progress" aria-label="Progress ${progress}%">
            <div class="pc-bar"><span style="width:${progress}%"></span></div>
            <span class="pc-pct">${progress}%</span>
          </div>
        </a>`;
      })
      .join('');
    state.hidden = true;
    grid.hidden = false;
  })();
</script>

<!-- is:global + .app-content prefix: required because project cards are injected
     via innerHTML (scoped styles don't reach injected DOM); the prefix keeps
     these rules from leaking onto marketing pages (e.g. about.astro's .timeline). -->
<style is:global>
  .app-top .app-title { font-weight: 600; font-size: 0.95rem; color: var(--text); }

  .app-content .page-head { margin-bottom: var(--s-12); }
  .app-content .page-head h1 { font-family: var(--font-display); font-size: clamp(2.2rem, 4vw, 3rem); text-transform: uppercase; letter-spacing: 0.01em; }
  .app-content .page-sub { color: var(--text-muted); margin-top: var(--s-2); }
  .app-content .portal-loading { color: var(--text-muted); font-family: var(--font-mono); font-size: 0.9rem; }

  .app-content .project-grid { display: grid; gap: var(--s-6); }
  @media (min-width: 720px) { .app-content .project-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1080px) { .app-content .project-grid { grid-template-columns: repeat(3, 1fr); } }

  .app-content .project-card {
    display: block; color: var(--text); background: var(--surface);
    border: 1px solid var(--border); border-radius: var(--r-lg);
    padding: var(--s-6); box-shadow: var(--shadow-sm);
    transition: border-color .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  .app-content .project-card:hover { border-color: var(--border-strong); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .app-content .project-card h3 { margin: var(--s-3) 0 var(--s-2); font-size: 1.1rem; }
  .app-content .pc-top { display: flex; align-items: center; justify-content: space-between; gap: var(--s-3); }
  .app-content .pc-date { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-subtle); }
  .app-content .pc-summary { font-size: 0.92rem; color: var(--text-muted); margin-bottom: var(--s-4); }
  .app-content .pc-progress { display: flex; align-items: center; gap: var(--s-3); margin-top: var(--s-5); }
  .app-content .pc-bar { flex: 1; height: 6px; border-radius: var(--r-full); background: var(--bg-alt); overflow: hidden; }
  .app-content .pc-bar span { display: block; height: 100%; background: var(--accent); border-radius: var(--r-full); }
  .app-content .pc-pct { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-subtle); }

  /* Dashed empty state (Bland-style "create your first…" card) */
  .app-content .empty-card {
    border: 1.5px dashed var(--border-strong); border-radius: var(--r-lg);
    padding: var(--s-16) var(--s-8); text-align: center;
    display: grid; justify-items: center; gap: var(--s-3);
    background: color-mix(in srgb, var(--surface) 60%, transparent);
  }
  .app-content .empty-ico { width: 46px; height: 46px; color: var(--text-subtle); display: grid; place-items: center; }
  .app-content .empty-ico svg { width: 30px; height: 30px; }
  .app-content .empty-card h3 { font-size: 1.15rem; }
  .app-content .empty-card p { color: var(--text-muted); max-width: 420px; }
  .app-content .empty-card a { color: var(--accent); }
</style>
