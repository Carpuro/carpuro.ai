# carpuro.ai — environment variables template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# In production these live in Vercel:
#   Project → Settings → Environment Variables (Production / Preview / Development)
# Locally they're read by `vercel dev` from `.env`.

# ── Supabase (chat logging + leads) ─────────────────────────────
# Supabase → Project Settings → API
# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=
# The SECRET service_role key (sb_secret_…, NOT the public publishable key). Server-side only.
SUPABASE_SERVICE_KEY=
# Optional — the public publishable key (sb_publishable_…). Not used by the app; safe to share.
SUPABASE_PUBLISHABLE_KEY=

# ── Google Gemini (Mon chat replies) ────────────────────────────
# https://aistudio.google.com/apikey  — free tier, used by api/chat.js (gemini-2.5-flash)
GEMINI_API_KEY=

# ── Cal.com (booking) ───────────────────────────────────────────
# Cal.com → Settings → Developer → API Keys. Not used yet (booking is the public
# embed link carpuro/discovery-call); reserved for server-side booking/lead sync.
CAL_API_KEY=

# ── Vercel (deploys / env sync via the `vercel` CLI) ────────────
# Account token: Vercel → Settings → Tokens. Used by the `vercel` CLI and
# scripts. NOTE: the Vercel MCP (mcp.vercel.com) authenticates via OAuth and
# does NOT read this token. ORG/PROJECT ids come from `.vercel/project.json`
# after `vercel link`, or Project → Settings → General.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Cloudflare (WAF / rate limiting / SSL config via the CF API) ─────
# Used only to manage edge security config for carpuro.ai — NOT by the app at
# runtime, and NOT needed in Vercel. Keep this local only.
# API_TOKEN: Cloudflare → My Profile → API Tokens → Create Token → Custom token.
#   Least-privilege scopes: Zone › Zone Settings › Edit + Zone › Zone WAF › Edit
#   (or Rate Limit), restricted to the carpuro.ai zone. Not the Global API Key.
# ACCOUNT_ID: dashboard → any domain → Overview, right sidebar ("Account ID").
# ZONE_ID:    dashboard → carpuro.ai → Overview, right sidebar ("Zone ID").
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ── GitHub (PR / CI management via the REST API) ────────────────
# Used only to manage the carpuro.ai repo (close PRs, comment, read CI status)
# from the local control plane — NOT by the app at runtime, NOT needed in Vercel.
# Fine-grained PAT (recommended): GitHub → Settings → Developer settings →
#   Personal access tokens → Fine-grained → owner=Carpuro, repo=carpuro.ai only,
#   permissions: Pull requests R/W, Contents R/W, Checks/Actions Read, Metadata Read.
#   (A classic token with the single `repo` scope also works, but is broader.)
GITHUB_TOKEN=
GITHUB_REPO=Carpuro/carpuro.ai

# ── Optional: Supabase MCP (lets Claude run migrations / read tables) ──
# Personal access token: Supabase → Account → Access Tokens
# The project ref is the subdomain of SUPABASE_URL (the "abcdefghijklmno" part).
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
